const express = require('express');
const app = express();
const PORT = process.env.PORT || 3000;

app.get('/', (req, res) => {
  res.send('<h1>Node.js App is Running!</h1><p>Connected to GitHub successfully.</p>');
});

app.listen(PORT, () => {
  console.log(`Server is live at http://localhost:${PORT}`);
});
